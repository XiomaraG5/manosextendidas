# ─────────────────────────────────────────────────────────────
# Configuración de Firebase (la copias desde la consola de Firebase:
# Configuración del proyecto → Tus apps → SDK de configuración).
# Estas claves son públicas por diseño; la seguridad vive en las reglas.
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Correos autorizados a entrar al panel /panel (separados por coma).
# Deben coincidir con la lista en firestore.rules.
NEXT_PUBLIC_ADMIN_EMAILS=correo1@gmail.com,correo2@gmail.com

# ─────────────────────────────────────────────────────────────
# Cloudinary (almacenamiento de imágenes, gratis y sin tarjeta).
# Crea un "unsigned upload preset" en cloudinary.com.
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
